API_TITLE=Semantic Programming Search API
API_VERSION=1.0.0
GITHUB_MODELS_API_KEY=replace_in_host_secret_store
GITHUB_MODELS_ENDPOINT=https://models.inference.ai.azure.com/embeddings
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_TIMEOUT_SECONDS=45
EMBEDDING_MAX_RETRIES=5
EMBEDDING_BASE_BACKOFF_SECONDS=1.0
FAISS_INDEX_PATH=../../data/index/question_index.faiss
ID_MAP_PATH=../../data/index/id_map.npy
LOOKUP_MAP_PATH=../../data/index/record_lookup.json
DEFAULT_TOP_K=10
CORS_ORIGINS=https://your-frontend-domain.vercel.app
