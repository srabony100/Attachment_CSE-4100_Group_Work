API_TITLE=Semantic Programming Search API
API_VERSION=0.1.0
GITHUB_MODELS_API_KEY=your_key_here
GITHUB_MODELS_ENDPOINT=https://models.inference.ai.azure.com/embeddings
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_TIMEOUT_SECONDS=45
EMBEDDING_MAX_RETRIES=5
EMBEDDING_BASE_BACKOFF_SECONDS=1.0
FAISS_INDEX_PATH=../../data/index/question_index.faiss
ID_MAP_PATH=../../data/index/id_map.npy
LOOKUP_MAP_PATH=../../data/index/record_lookup.json
DEFAULT_TOP_K=10
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
DATABASE_URL=sqlite:///../../data/app.db
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ISSUER=semantic-search-api
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=720
COOKIE_SECURE=false
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeThisAdminPass123
UPLOAD_DIR=../uploads
MAX_UPLOAD_SIZE_BYTES=5242880
